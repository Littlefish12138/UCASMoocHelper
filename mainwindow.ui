           <widget class="QGroupBox" name="logGroup">
            <property name="minimumSize">
             <size>
              <width>0</width>
              <height>200</height>
             </size>
            </property>
            <property name="styleSheet">
             <string notr="true">
              QGroupBox#logGroup {
                  background-color: #1E1E1E;
                  border: 1px solid #333333;
                  border-radius: 8px;
                  margin-top: 14px;
                  padding: 16px 10px 10px 10px;
                  font-size: 13pt;
                  font-weight: bold;
                  color: #CCCCCC;
              }
              QGroupBox#logGroup::title {
                  subcontrol-origin: margin;
                  subcontrol-position: top left;
                  padding: 0 8px;
                  color: #CCCCCC;
                  background: #1E1E1E;
              }
              /* 日志区内部滚动条覆盖为暗色 */
              QGroupBox#logGroup QScrollBar:vertical {
                  background: #2D2D2D;
                  width: 8px;
                  margin: 2px 0 2px 0;
              }
              QGroupBox#logGroup QScrollBar::handle:vertical {
                  background: #555555;
                  border-radius: 4px;
                  min-height: 30px;
              }
              QGroupBox#logGroup QScrollBar::handle:vertical:hover {
                  background: #777777;
              }
              QGroupBox#logGroup QScrollBar::add-line:vertical,
              QGroupBox#logGroup QScrollBar::sub-line:vertical {
                  height: 0px;
                  background: none;
                  border: none;
              }
              QGroupBox#logGroup QScrollBar::add-page:vertical,
              QGroupBox#logGroup QScrollBar::sub-page:vertical {
                  background: none;
              }
              QGroupBox#logGroup QScrollBar:horizontal {
                  background: #2D2D2D;
                  height: 8px;
                  margin: 0 2px 0 2px;
              }
              QGroupBox#logGroup QScrollBar::handle:horizontal {
                  background: #555555;
                  border-radius: 4px;
                  min-width: 30px;
              }
              QGroupBox#logGroup QScrollBar::handle:horizontal:hover {
                  background: #777777;
              }
              QGroupBox#logGroup QScrollBar::add-line:horizontal,
              QGroupBox#logGroup QScrollBar::sub-line:horizontal {
                  width: 0px;
                  background: none;
                  border: none;
              }
              QGroupBox#logGroup QScrollBar::add-page:horizontal,
              QGroupBox#logGroup QScrollBar::sub-page:horizontal {
                  background: none;
              }
             </string>
            </property>
            <property name="title">
             <string>运行日志</string>
            </property>
            <layout class="QVBoxLayout" name="logGroupLayout">
             <property name="spacing">
              <number>8</number>
             </property>
