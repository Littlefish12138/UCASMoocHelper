                     <string notr="true">QPushButton {
    border: 2px solid #cccccc;
    border-radius: 10px;
    background: transparent;
    width: 40px;
    height: 20px;
}

/* 鼠标悬停效果 */
QPushButton:hover {
    border-color: #666666;
    background: rgba(200, 200, 200, 0.1);
}

/* 鼠标按下效果 */
QPushButton:pressed {
    border-color: #333333;
    background: rgba(150, 150, 150, 0.2);
}

/* 禁用状态（如果需要） */
QPushButton:disabled {
    border-color: #e0e0e0;
}</string>
