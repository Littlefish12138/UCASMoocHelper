  <property name="styleSheet">
   <string notr="true">
    /* ============================================================ */
    /*  全局样式表                                                   */
    /* ============================================================ */
    QMainWindow {
        background-color: #F3F4F6;
    }

    /* ---------- QGroupBox ---------- */
    QGroupBox {
        background-color: #FFFFFF;
        border: 1px solid #E0E3E8;
        border-radius: 8px;
        margin-top: 14px;
        padding: 16px 12px 12px 12px;
        font-size: 13pt;
        font-weight: bold;
        color: #1F2937;
    }
    QGroupBox::title {
        subcontrol-origin: margin;
        subcontrol-position: top left;
        padding: 0 8px;
        color: #111827;
    }

    /* ---------- QRadioButton / QCheckBox 文本 ---------- */
    QRadioButton, QCheckBox {
        font-size: 10pt;
        color: #1467ec;
        spacing: 8px;
    }

    QRadioButton, QCheckBox {
        font-size: 10pt;
        color: #00050d;
        spacing: 6px;
    }
    QRadioButton::indicator, QCheckBox::indicator {
        width: 16px;
        height: 16px;
    }

    /* ---------- QLineEdit ---------- */
    QLineEdit {
        border: 1px solid #D1D5DB;
        border-radius: 4px;
        padding: 5px 8px;
        font-size: 10pt;
        background-color: #FAFBFC;
        color: #1F2937;
        selection-background-color: #BFDBFE;
    }
    QLineEdit:focus {
        border: 1px solid #3B82F6;
        background-color: #FFFFFF;
    }
    QLineEdit:disabled {
        background-color: #E5E7EB;
        color: #9CA3AF;
    }

    /* ---------- QToolButton ---------- */
    QToolButton {
        border: 1px solid #D1D5DB;
        border-radius: 4px;
        padding: 5px 10px;
        font-size: 11pt;
        background-color: #F9FAFB;
        color: #374151;
    }
    QToolButton:hover {
        background-color: #E5E7EB;
        border-color: #9CA3AF;
    }
    QToolButton:pressed {
        background-color: #D1D5DB;
    }

    /* ---------- QPushButton 通用 ---------- */
    QPushButton {
        border: 1px solid #D1D5DB;
        border-radius: 5px;
        padding: 6px 16px;
        font-size: 10pt;
        background-color: #F9FAFB;
        color: #374151;
    }
    QPushButton:hover {
        background-color: #E5E7EB;
    }

    /* ---------- 开始执行按钮 ---------- */
    QPushButton#startBtn {
        background-color: #2563EB;
        color: #FFFFFF;
        border: none;
        font-size: 12pt;
        font-weight: bold;
        padding: 10px 32px;
        border-radius: 6px;
    }
    QPushButton#startBtn:hover {
        background-color: #1D4ED8;
    }
    QPushButton#startBtn:pressed {
        background-color: #1E40AF;
    }

    /* ---------- 折叠按钮 ---------- */
    QPushButton#toggleLaunchBtn {
        background: transparent;
        border: none;
        color: #3B82F6;
        font-size: 10pt;
        font-weight: bold;
        padding: 4px 0px;
        text-align: left;
    }
    QPushButton#toggleLaunchBtn:hover {
        color: #1D4ED8;
    }

    /* ---------- 任务类型 Radio（加粗） ---------- */
    QRadioButton#completeCourseRadio,
    QRadioButton#saveQuestionsRadio {
        font-weight: bold;
        font-size: 11pt;
    }

    /* ===== QScrollBar：全局圆角细条 ===== */
    QScrollBar:vertical {
        background: transparent;
        width: 8px;
        margin: 2px 0 2px 0;
    }
    QScrollBar::handle:vertical {
        background: #D1D5DB;
        border-radius: 4px;
        min-height: 30px;
    }
    QScrollBar::handle:vertical:hover {
        background: #9CA3AF;
    }
    QScrollBar::handle:vertical:pressed {
        background: #6B7280;
    }
    QScrollBar::add-line:vertical,
    QScrollBar::sub-line:vertical {
        height: 0px;
        background: none;
        border: none;
    }
    QScrollBar::add-page:vertical,
    QScrollBar::sub-page:vertical {
        background: none;
    }

    QScrollBar:horizontal {
        background: transparent;
        height: 8px;
        margin: 0 2px 0 2px;
    }
    QScrollBar::handle:horizontal {
        background: #D1D5DB;
        border-radius: 4px;
        min-width: 30px;
    }
    QScrollBar::handle:horizontal:hover {
        background: #9CA3AF;
    }
    QScrollBar::handle:horizontal:pressed {
        background: #6B7280;
    }
    QScrollBar::add-line:horizontal,
    QScrollBar::sub-line:horizontal {
        width: 0px;
        background: none;
        border: none;
    }
    QScrollBar::add-page:horizontal,
    QScrollBar::sub-page:horizontal {
        background: none;
    }

    /* ---------- QScrollArea ---------- */
    QScrollArea {
        border: none;
    }
   </string>
  </property>
