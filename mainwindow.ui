                      <item alignment="Qt::AlignmentFlag::AlignHCenter">
                       <widget class="QRadioButton" name="edgeRadio">
                        <property name="styleSheet">
                         <string notr="true">QRadioButton {
    font-family: &quot;Segoe UI&quot;, &quot;Microsoft YaHei&quot;;
    font-size: 14px;
    spacing: 8px;
    color: #2C3E50;
    background: transparent;
}

/* 指示器（圆形按钮）基础样式 */
QRadioButton::indicator {
    width: 13px;
    height: 13px;
    border-radius: 7px;          /* 完全圆形 */
    border: 2px solid #B0BEC5;   /* 未选中边框灰色 */
    background: #FFFFFF;         /* 内部始终白色 */
}

/* 悬停效果（边框变色，内部保持白色） */
QRadioButton::indicator:hover {
    border-color: #42A5F5;
    background: #FFFFFF;
}

/* 选中状态：边框改为深蓝色，内部通过径向渐变绘制蓝色同心圆（中心蓝色，边缘留白） */
QRadioButton::indicator:checked {
    border-color: #1976D2;                     /* 深蓝色边框 */
    background: qradialgradient(
        cx: 0.5, cy: 0.5, radius: 0.5,
        fx: 0.5, fy: 0.5,
        stop: 0 #1976D2,                       /* 圆心纯蓝色 */
        stop: 0.6 #1976D2,                     /* 半径 60% 范围内保持纯蓝 */
        stop: 0.61 #FFFFFF                     /* 半径 60% 外变为白色，形成留白边缘 */
    );
}

/* 选中且悬停时：维持同心圆渐变，边框可稍作加强（可选） */
QRadioButton::indicator:checked:hover {
    border-color: #1E88E5;                     /* 略亮一点的深蓝边框，保持视觉反馈 */
    background: qradialgradient(
        cx: 0.5, cy: 0.5, radius: 0.5,
        fx: 0.5, fy: 0.5,
        stop: 0 #1976D2,
        stop: 0.6 #1976D2,
        stop: 0.61 #FFFFFF
    );
}</string>
